{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC (Debug)",
      "description": "Visual Studio cl.exe + Ninja, Debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "vendor": {
        "microsoft.com/VisualStudioSettings/CMake/1.0": {
          "hostOS": [ "Windows" ]
        }
      },
      "toolset": { "value": "host=x64", "strategy": "external" },
      "architecture": { "value": "x64", "strategy": "external" }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC (Release)",
      "inherits": "windows-msvc-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },

    {
      "name": "windows-vs-2022",
      "displayName": "Windows Visual Studio 2022 (multi-config)",
      "description": "Use the Visual Studio generator instead of Ninja. Build configuration is chosen at build time.",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },

    {
      "name": "linux-debug",
      "displayName": "Linux (Debug)",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-release",
      "displayName": "Linux (Release)",
      "inherits": "linux-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    }
  ],

  "buildPresets": [
    { "name": "windows-msvc-debug",   "configurePreset": "windows-msvc-debug" },
    { "name": "windows-msvc-release", "configurePreset": "windows-msvc-release" },
    { "name": "windows-vs-2022",      "configurePreset": "windows-vs-2022", "configuration": "RelWithDebInfo" },
    { "name": "linux-debug",          "configurePreset": "linux-debug" },
    { "name": "linux-release",        "configurePreset": "linux-release" }
  ]
}
